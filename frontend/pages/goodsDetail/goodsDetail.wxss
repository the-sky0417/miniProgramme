.page { padding: 20rpx; }
.goods-panel { background: #fff; border-radius: 20rpx; padding: 20rpx; }
.detail-image { width: 100%; height: 420rpx; border-radius: 20rpx; }
.detail-info { padding-top: 20rpx; }
.detail-title { font-size: 34rpx; color: #333; font-weight: bold; }
.detail-price { font-size: 32rpx; color: #1AAD19; margin: 18rpx 0; }
.detail-desc { color: #666; line-height: 40rpx; }
.actions { display: flex; justify-content: space-between; margin-top: 30rpx; }
.actions button { width: 48%; }
