<view class="page">
  <view class="order-filter card">
    <button bindtap="filterStatus" data-status="all">全部</button>
    <button bindtap="filterStatus" data-status="待付款">待付款</button>
    <button bindtap="filterStatus" data-status="待发货">待发货</button>
    <button bindtap="filterStatus" data-status="已完成">已完成</button>
  </view>
  <scroll-view scroll-y class="order-list" bindscrolltolower="onReachBottom" lower-threshold="100">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card">
        <text class="order-no">订单号：{{item.order_no}}</text>
        <text>状态：{{item.status}}</text>
        <text>总价：￥{{item.total_price}}</text>
        <navigator url="/pages/orders/orderDetail?id={{item.id}}">查看详情</navigator>
      </view>
    </block>
    <view class="loading">{{loadingText}}</view>
  </scroll-view>
</view>
