.page { padding: 20rpx; }
.search-bar { display: flex; align-items: center; margin-bottom: 20rpx; }
.search-input { flex: 1; height: 60rpx; padding: 0 20rpx; border: 1rpx solid #ddd; border-radius: 10rpx; }
.goods-list { height: calc(100vh - 140rpx); }
.goods-item { display: flex; margin-bottom: 20rpx; background: #fff; padding: 20rpx; border-radius: 20rpx; }
.goods-image { width: 220rpx; height: 220rpx; border-radius: 20rpx; }
.goods-info { flex: 1; padding-left: 20rpx; justify-content: space-between; }
.goods-name { font-size: 30rpx; color: #333; }
.goods-price { font-size: 28rpx; color: #1AAD19; margin-top: 20rpx; }
.loading { padding: 20rpx; text-align: center; color: #999; }
