<view class="page">
  <view class="card">
    <swiper indicator-dots autoplay interval="3000" circular>
      <block wx:for="{{banners}}" wx:key="id">
        <swiper-item>
          <image src="{{item.image}}" mode="aspectFill" style="width:100%;height:320rpx;"></image>
        </swiper-item>
      </block>
    </swiper>
  </view>
  <view class="card">
    <view class="navbar">
      <text>热销商品</text>
      <navigator url="/pages/goods/goods">更多</navigator>
    </view>
    <block wx:for="{{goodsList}}" wx:key="id">
      <navigator url="/pages/goodsDetail/goodsDetail?id={{item.id}}" class="goods-item">
        <image src="{{item.cover}}" mode="aspectFill" class="goods-image"></image>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">￥{{item.price}}</text>
        </view>
      </navigator>
    </block>
  </view>
</view>
