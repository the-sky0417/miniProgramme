<view class="page">
  <view class="profile-card card">
    <image src="{{userInfo.avatarUrl || '/assets/avatar_placeholder.png'}}" class="avatar"></image>
    <view class="profile-info">
      <text class="name">{{userInfo.nickName || '游客'}}</text>
      <text class="hint">{{userInfo.gender === 1 ? '男' : userInfo.gender === 2 ? '女' : '未授权'}}</text>
    </view>
    <button bindtap="onLogin" class="button-primary">登录</button>
  </view>
  <view class="card">
    <navigator url="/pages/orders/orders">我的订单</navigator>
  </view>
</view>
